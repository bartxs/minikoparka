---
const base = import.meta.env.BASE_URL;
const photos = [
  { src: `${base}images/truck.webp`, alt: 'Wywrotka 4x4 — widok z przodu', caption: 'Wywrotka 4×4' },
  { src: `${base}images/excavator.webp`, alt: 'Minikoparkas w pracy', caption: 'Minikoparkas' },
  { src: `${base}images/truck2.webp`, alt: 'Wywrotka podczas rozładunku', caption: 'Transport materiałów' },
  { src: `${base}images/excavator2.webp`, alt: 'Prace ziemne — wykop', caption: 'Roboty ziemne' },
];
---

<section id="galeria" class="bg-charcoal py-20 px-4 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12">
      <span class="inline-block text-amber text-xs font-semibold uppercase tracking-widest mb-3">Sprzęt i realizacje</span>
      <h2 class="font-display font-bold uppercase text-4xl sm:text-5xl text-concrete leading-tight">
        Galeria
      </h2>
    </div>

    <!-- Photo grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      {photos.map((photo, i) => (
        <div
          class:list={[
            'relative overflow-hidden group cursor-pointer',
            i === 0 ? 'col-span-2 row-span-2 aspect-square' : 'aspect-square',
          ]}
          data-lightbox-index={i}
        >
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-charcoal/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
            <span class="font-display font-bold uppercase text-sm text-concrete">{photo.caption}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Placeholder note for more photos -->
    <div class="mt-8 p-6 border border-dashed border-white/10 text-center">
      <p class="text-concrete/40 text-sm">
        Więcej zdjęć realizacji dostępnych na żądanie — <a href="tel:+48XXXXXXXXX" class="text-amber hover:underline">zadzwoń</a> lub napisz na WhatsApp.
      </p>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-charcoal/95 hidden items-center justify-center p-4" role="dialog" aria-modal="true">
  <button id="lightbox-close" class="absolute top-4 right-4 text-concrete/60 hover:text-concrete p-2" aria-label="Zamknij">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain" />
  <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 font-display uppercase text-concrete/60 text-sm tracking-widest"></p>
</div>

<script>
  const base = import.meta.env.BASE_URL;
  const photos = [
    { src: `${base}images/truck.webp`, alt: 'Wywrotka 4x4', caption: 'Wywrotka 4×4' },
    { src: `${base}images/excavator.webp`, alt: 'Minikoparkas w pracy', caption: 'Minikoparkas' },
    { src: `${base}images/truck2.webp`, alt: 'Wywrotka podczas rozładunku', caption: 'Transport materiałów' },
    { src: `${base}images/excavator2.webp`, alt: 'Prace ziemne', caption: 'Roboty ziemne' },
  ];

  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbClose = document.getElementById('lightbox-close');

  document.querySelectorAll('[data-lightbox-index]').forEach(el => {
    el.addEventListener('click', () => {
      const idx = parseInt((el as HTMLElement).dataset.lightboxIndex || '0');
      const p = photos[idx];
      if (lbImg) { lbImg.src = p.src; lbImg.alt = p.alt; }
      if (lbCaption) lbCaption.textContent = p.caption;
      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  const closeLightbox = () => {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.style.overflow = '';
  };

  lbClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>

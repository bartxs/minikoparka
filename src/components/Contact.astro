---
const PHONE = '+48 XXX XXX XXX';
const PHONE_HREF = 'tel:+48XXXXXXXXX';
const WHATSAPP_HREF = 'https://wa.me/48XXXXXXXXX?text=Dzień dobry, chciałbym zapytać o wycenę.';
---

<section id="kontakt" class="bg-charcoal py-20 px-4 border-t border-white/5">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Header -->
    <span class="inline-block text-amber text-xs font-semibold uppercase tracking-widest mb-3">Skontaktuj się</span>
    <h2 class="font-display font-bold uppercase text-4xl sm:text-6xl text-concrete leading-tight mb-4">
      Darmowa wycena
    </h2>
    <p class="text-concrete/60 text-base max-w-lg mx-auto mb-12">
      Zadzwoń lub napisz — odpowiadamy szybko, wycena bez zobowiązań.
      Działamy w dni robocze i weekendy.
    </p>

    <!-- Primary contact options -->
    <div class="grid sm:grid-cols-2 gap-4 max-w-xl mx-auto mb-12">
      <!-- Phone -->
      <a
        href={PHONE_HREF}
        class="flex flex-col items-center gap-3 bg-amber hover:bg-amber-dark text-charcoal p-8 transition-colors group"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        <span class="font-display font-bold uppercase text-xl tracking-wide">{PHONE}</span>
        <span class="text-xs font-medium uppercase tracking-widest opacity-70">Zadzwoń teraz</span>
      </a>

      <!-- WhatsApp -->
      <a
        href={WHATSAPP_HREF}
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-3 bg-smoke hover:bg-white/5 border border-white/10 text-concrete p-8 transition-colors group"
      >
        <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="font-display font-bold uppercase text-xl tracking-wide">WhatsApp</span>
        <span class="text-xs font-medium uppercase tracking-widest text-concrete/50">Napisz wiadomość</span>
      </a>
    </div>

    <!-- Simple contact form -->
    <div class="bg-smoke border border-white/5 p-8 max-w-xl mx-auto text-left">
      <h3 class="font-display font-bold uppercase text-xl text-concrete mb-6">Formularz zapytania</h3>
      <form
        id="contact-form"
        class="space-y-4"
        novalidate
      >
        <div>
          <label class="block text-xs text-concrete/50 uppercase tracking-widest mb-1.5" for="name">Imię i nazwisko</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="Jan Kowalski"
            class="w-full bg-charcoal border border-white/10 focus:border-amber text-concrete placeholder-concrete/30 px-4 py-3 text-sm outline-none transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs text-concrete/50 uppercase tracking-widest mb-1.5" for="phone-input">Telefon</label>
          <input
            id="phone-input"
            name="phone"
            type="tel"
            required
            placeholder="+48 XXX XXX XXX"
            class="w-full bg-charcoal border border-white/10 focus:border-amber text-concrete placeholder-concrete/30 px-4 py-3 text-sm outline-none transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs text-concrete/50 uppercase tracking-widest mb-1.5" for="message">Wiadomość</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            placeholder="Opisz czego potrzebujesz — lokalizacja, rodzaj pracy, orientacyjny termin..."
            class="w-full bg-charcoal border border-white/10 focus:border-amber text-concrete placeholder-concrete/30 px-4 py-3 text-sm outline-none transition-colors resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-amber hover:bg-amber-dark text-charcoal font-display font-bold uppercase tracking-wide py-4 transition-colors"
        >
          Wyślij zapytanie
        </button>
        <p id="form-note" class="text-xs text-concrete/40 text-center">
          Odpowiadamy zazwyczaj w ciągu kilku godzin.
        </p>
      </form>
    </div>

    <!-- Hours -->
    <div class="mt-8 text-concrete/40 text-sm">
      <span class="font-semibold text-concrete/60">Godziny pracy:</span> Pon–Sob 7:00–18:00 · Niedziela na telefon
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const note = document.getElementById('form-note');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const phone = (data.get('phone') as string) || '';
    const name = (data.get('name') as string) || '';
    const message = (data.get('message') as string) || '';

    const waText = encodeURIComponent(`Dzień dobry, ${name}. Telefon: ${phone}. ${message}`);
    window.open(`https://wa.me/48XXXXXXXXX?text=${waText}`, '_blank');

    if (note) note.textContent = 'Dziękujemy! Otworzyliśmy WhatsApp z Twoją wiadomością.';
    form.reset();
  });
</script>
